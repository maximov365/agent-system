#!/usr/bin/env python3
"""
Pre-commit hook: auto-bump VERSION patch number when framework files change.

Checks staged files against FRAMEWORK_GLOBS. If any framework file is staged,
increments the patch version (e.g., 1.2.3 → 1.2.4) and stages the updated
VERSION file alongside the commit.

Install:
    python hooks/install.py
"""

import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
VERSION_FILE = ROOT / "VERSION"

FRAMEWORK_GLOBS = [
    "agents/*.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".cursor/rules.md",
    "docs/AGENT_HANDOFF_CONTRACT.md",
    "docs/AGENT_EXECUTION_MODEL.md",
    "docs/TASK_BACKLOG_AUTOMATION.md",
    "docs/ARCHITECTURE_GUARDRAILS.md",
    "docs/ARCHITECTURE_CHECKLIST.md",
    "docs/TASK_TEMPLATE.md",
    "docs/ONBOARDING.md",
    "setup.py",
    "requirements-framework.txt",
]


def get_staged_files() -> set[str]:
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
        capture_output=True, text=True, cwd=str(ROOT),
    )
    return set(result.stdout.strip().splitlines())


def collect_framework_paths() -> set[str]:
    paths = set()
    for pattern in FRAMEWORK_GLOBS:
        for p in ROOT.glob(pattern):
            paths.add(str(p.relative_to(ROOT)))
    return paths


def bump_patch(version_str: str) -> str:
    parts = version_str.strip().split(".")
    if len(parts) != 3 or not all(p.isdigit() for p in parts):
        return version_str
    parts[2] = str(int(parts[2]) + 1)
    return ".".join(parts)


def main() -> int:
    if not VERSION_FILE.exists():
        return 0

    staged = get_staged_files()

    if "VERSION" in staged:
        return 0

    framework_paths = collect_framework_paths()
    changed_framework = staged & framework_paths

    if not changed_framework:
        return 0

    old_version = VERSION_FILE.read_text().strip()
    new_version = bump_patch(old_version)

    if old_version == new_version:
        return 0

    VERSION_FILE.write_text(new_version + "\n")

    subprocess.run(
        ["git", "add", str(VERSION_FILE)],
        cwd=str(ROOT),
    )

    print(f"  VERSION auto-bumped: {old_version} → {new_version}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
